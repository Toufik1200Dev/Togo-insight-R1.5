# ============================================================================
# Togo Insight R1.5 — environment variables
# Copy this file to ".env" (local) and set the same keys in Azure App Service
# Configuration → Application settings for production.
# ============================================================================

# ---- App ----
# Public base URL of the app. Locally: http://localhost:3000
# In Azure: https://<your-app-name>.azurewebsites.net
NEXTAUTH_URL=http://localhost:3000
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# ---- Database: Azure Database for PostgreSQL (Prisma postgresql provider) ----
# Azure example (Flexible Server — recommended for production):
# postgresql://<user>:<password>@<server>.postgres.database.azure.com:5432/<db>?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/togo_insight?schema=public"

# ---- Microsoft Entra ID (Azure AD) — "Login with Microsoft" ----
# App registration in Entra ID. Redirect URI:
#   <NEXTAUTH_URL>/api/auth/callback/azure-ad
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ---- Azure Blob Storage (file uploads) ----
AZURE_STORAGE_CONNECTION_STRING=
# Container that holds INPUT/ (uploads) and OUTPUT/ (processed) blobs
AZURE_STORAGE_CONTAINER=prodtogodata

# ---- Power BI Embedded (dashboards) ----
# Service principal (Entra app) granted access to the Power BI workspace.
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
# The workspace (group) and report you want to embed.
POWERBI_WORKSPACE_ID=
POWERBI_REPORT_ID=
# Optional: dataset id (needed for some RLS / token scenarios)
POWERBI_DATASET_ID=
